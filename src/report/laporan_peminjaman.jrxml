					<font size="10" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["Periode: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{dari_tanggal}) + " s/d " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{sampai_tanggal})]]></textFieldExpression>
			</textField>
			<line>
